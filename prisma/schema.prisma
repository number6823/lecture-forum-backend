// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// prisma를 통해 사용할 DB source 종류를 기록
datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

// 이 아랫부분에는 내가 실제 데이터베이스에 사용할 모델링을 기재 -> prisma의 문법을 통해

enum GenderType {
  MALE
  FEMALE
}

enum RoleType {
  ADMIN
  USER
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

// model 키워드는 Javascript에서는 객체가 되며, DB에서는 테이블이 됨
// 이 안에 기재하는 건, [칼럼명] [타입] [옵션] 으로 작성하고
// 옵션 -----
// @id : primary key
// @default : default
// @unique : unique
// @updatedAt : 해당 칼럼이 수정될 때 자동으로 들어가는 수정 시간 갱신 옵션
model User {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now()) // 삽입할 때 기본값으로 삽입 시간이 기록
  updatedAt   DateTime   @updatedAt // 수정할 때 기본적으로 수정 시간이 기록
  deletedAt   DateTime? // 타입에 ? 를 넣으면 null을 허용한다는 뜻
  username    String     @unique
  password    String
  name        String
  nickname    String     @unique
  email       String     @unique
  phoneNumber String?
  birthdate   DateTime?
  gender      GenderType
  role        RoleType   @default(USER) // 삽입할 때 기본값으로 USER 기록

  posts Post[]
  votes Vote[]
}

model Category {
  id        Int            @id @default(autoincrement())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  name      String         @unique
  status    CategoryStatus @default(ACTIVE)

  posts Post[]
}

// Post 테이블과 다른 테이블의 연관성을 생각해봐야 함
// 해당 데이터를 삭제해도 될 때에는, 자식 테이블이 없을 때 *연관성이 아예 존재치 않을 때)
// 2. 자식 테이블 까지 고려했을 때에도 중요하지 않을 때
// Post의 경우 Replies나, like 등 테이블과 연관성이 있다고 판단하더라도
// 삭제해도 괜찮은 데이터들임=> 소프트삭제를 하든, 진짜 삭제 처리를 하든, 문제는 없을 것이다라고 가정
// 1번이든 2번이든 진행하는건 내 맘이다
// Prisma에서는 부모 데이터가 삭제되면, 자식 데이터까지 모두 삭제하는 기능을 제공
model Post {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  title       String
  content     String    @db.Text // Javascript 에서는 String으로 동작하지만, DB 칼럼은 Text
  views       Int       @default(0)
  option1Text String?
  option2Text String?

  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  // relation울 맺는데, 이 글을 작성한 부모의 id값이 적혀지는 칼럼은 userId이고, 그 값으로 부모 테이블의 대상 칼럼은 id이다
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  votes      Vote[]

  @@index([userId])
  @@index([categoryId])
}

model Vote {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  option    Int // 몇 번에 투표했는지
  // Post에 자식, User에 자식
  userId    Int // 부모 유저를 찾을 수 있도록 하는 id값이 "실제 기록" 되는 칼럼
  user      User     @relation(fields: [userId], references: [id])
  postId    Int // 부모 글을 찾을 수 있도록 하는 id값이 "실제 기록" 되는 칼럼
  post      Post     @relation(fields: [postId], references: [id])
  // 데이터베이스는 데이터에 대한 저장을 담당하고, 그 데이터를 검색해 주는 장치
  // 빠르게 검색을 도와주는 도구로서 index라는게 존재함

  // 나중에 마이페이지를 만들 때 "내가 투표한 거"를 찾아달라고 이야기 할 것이고
  // 게시글 상세 페이지에서 postId를 기준으로 검색을 해야되니까.
  // 사실, PK든,FK든 key는 그냥  index를 걸어야 함

  // 투표라고 하는건, 1인 1투표를 기초로 함
  // userId에 unique를 걸면 그 사람은 모든 글을 통틀어 진짜 1번만 튜표가 가능해짐
  // postId에 unique를 걸면 모든 사람들 중 그 글에는 1번만 투표가 가능해짐
  // 그래서unique는 userId와 postId를 동시에 걸어야 함
  @@unique([userId, postId])
  // 모든 칼럼에 대해 색인을 만들 필요는 없음. 전화번호에 "ㄱ,ㄴ,ㄷ"로 만들지."김,이,최"로 만들진 않음
  // 오히려 색인이 많아지면 데이터베이스가 해야할 일이 많아질 뿐
  // 데이터베이스는 기본적으로 검색할 때 id(primary key)와 unique를 걸어준 것에 대해 색인을 만듦
  @@index([postId]) // foreign key
  @@index([userId]) // foreign key
}
